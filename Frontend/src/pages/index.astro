---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Plataforma interactiva de aprendizaje matemático." } = Astro.props;
import '../css/main.css';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} | Aula Calma</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
    </style>
  </head>
  
  <body class="bg-[#f8fafc] text-slate-700 antialiased min-h-screen flex flex-col justify-between">
    
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200/60 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-6 h-16 flex justify-between items-center">
        
        <a href="/" class="font-bold text-slate-800 tracking-tight flex items-center gap-2 text-base transition-transform active:scale-95">
          <span class="text-xl bg-sky-50 p-1.5 rounded-xl border border-sky-100/80">🍃</span> 
          <span>Aula<span class="text-sky-600 font-medium">Calma</span></span>
        </a>
        
        <div id="student-badge" class="opacity-0 transition-opacity duration-300 flex items-center gap-2.5 bg-sky-50 border border-sky-100 px-3 py-1 rounded-full">
          <div class="w-6 h-6 rounded-full bg-sky-500 flex items-center justify-center text-xs shadow-sm select-none">
            👋
          </div>
          <span id="student-name-text" class="text-xs font-bold text-sky-800 tracking-wide"></span>
        </div>
        
      </div>
    </header>

    <div id="name-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden opacity-0 transition-all duration-300">
      <div class="bg-white rounded-2xl border border-slate-100 shadow-xl max-w-sm w-full p-6 text-center space-y-5 transform scale-95 transition-transform duration-300">
        <div class="text-3xl">✨</div>
        <div class="space-y-1">
          <h3 class="text-lg font-bold text-slate-800">¡Te damos la bienvenida!</h3>
          <p class="text-slate-500 text-xs">Por favor, dinos tu nombre para comenzar tu aventura de aprendizaje.</p>
        </div>
        <form id="name-form" class="space-y-4">
          <input 
            type="text" 
            id="name-input" 
            required 
            maxlength="15"
            placeholder="Escribe tu nombre aquí..." 
            class="w-full px-4 py-2.5 text-center text-sm border border-slate-200 rounded-xl focus:border-sky-500 focus:ring-1 focus:ring-sky-500 focus:outline-none transition-all"
          />
          <button type="submit" class="w-full bg-sky-600 hover:bg-sky-700 text-white text-xs font-bold py-2.5 rounded-xl transition-all shadow-sm" id="start-button">
            Comenzar clase
          </button>
        </form>
      </div>
    </div>

    <main class="w-full max-w-4xl mx-auto px-4 md:px-6 py-10 flex-grow flex flex-col justify-center items-center">
      <slot /> 
    </main>

    <footer class="bg-white border-t border-slate-200/40 py-6 text-center text-[11px] text-slate-400 font-medium tracking-wide">
      <div class="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-2">
        <p>Aula Calma — Espacio de Aprendizaje Dinámico</p>
        <p class="bg-slate-50 px-2 py-0.5 rounded border border-slate-100">La sesión expira al cerrar la pestaña</p>
      </div>
    </footer>

    <script>
  const modal = document.getElementById('name-modal');
const modalContent = modal?.querySelector('div');
const form = document.getElementById('name-form') as HTMLFormElement;
const input = document.getElementById('name-input') as HTMLInputElement;
const badge = document.getElementById('student-badge');
const badgeText = document.getElementById('student-name-text');

function actualizarInterfazNombre(nombre: string) {
  if (badge && badgeText) {
    badgeText.textContent = nombre;
    badge.classList.remove('opacity-0');
  }
}

function verificarSesion() {
  const nombreGuardado = sessionStorage.getItem('student_name');

  if (nombreGuardado) {
    actualizarInterfazNombre(nombreGuardado);
    if (window.location.pathname !== './first_content') {
      window.location.href = './first_content';
    }
  } else {
    if (modal && modalContent) {
      modal.classList.remove('hidden');
      setTimeout(() => {
        modal.classList.remove('opacity-0');
        modalContent.classList.remove('scale-95');
      }, 50);
    }
  }
}

form?.addEventListener('submit', (e) => {
  e.preventDefault();
  const nombre = input.value.trim();
  
  if (nombre && modal && modalContent) {
    sessionStorage.setItem('student_name', nombre);
    
    if (!sessionStorage.getItem('random_user_id')) {
      const userId = 'user_' + Math.random().toString(36).substring(2, 8);
      sessionStorage.setItem('random_user_id', userId);
    }

    actualizarInterfazNombre(nombre);
    window.location.href = './first_content';
    modal.classList.add('opacity-0');
    modalContent.classList.add('scale-95');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 300);
  }
});

verificarSesion();
    </script>
  </body>
</html>