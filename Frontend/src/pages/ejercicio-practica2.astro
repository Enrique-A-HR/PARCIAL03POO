---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import '../css/main.css';
import dibujoPedagogico from '../assets/focaalegre.png';
import dibujoSuccess from '../assets/torogozlearned.png';
---

<Layout title="Práctica Avanzada: Completa la recta numérica">
  <div class="w-full max-w-3xl bg-white border border-slate-200/80 rounded-2xl p-6 md:p-10 shadow-sm space-y-10">
    
    <header class="border-b border-slate-100 pb-4 flex justify-between items-center flex-wrap gap-4">
      <div class="space-y-1">
        <h1 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <span class="bg-amber-100 text-amber-700 text-xs px-2.5 py-1 rounded-md font-mono">Reto Final</span>
          Hola, <span id="student-display-name" class="text-sky-600">estudiante</span> ✨
        </h1>
        <p class="text-slate-500 text-xs">Escribe el número que falta en cada recta numérica usando tu teclado.</p>
      </div>
      <div class="bg-slate-50 border border-slate-200 text-slate-600 text-xs font-mono px-3 py-1 rounded-lg">
        Ejercicios: 4 / 4
      </div>
    </header>

    <form id="practice-form" class="space-y-8" onsubmit="return false;">
      
      <div class="bg-slate-50/50 border border-slate-200/60 rounded-xl p-5 space-y-4">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block">Ejercicio 1</span>
        <div class="relative w-full flex justify-between items-center py-6 px-4 bg-white border border-slate-100 rounded-lg shadow-sm">
          <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-slate-300 -translate-y-1/2"></div>
          
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">120</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">121</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">122</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-16 bg-white">
            <input type="number" data-answer="123" required class="exercise-input w-16 text-center font-mono font-bold text-sm text-sky-700 bg-sky-50/50 border-2 border-sky-300 rounded-lg p-1 focus:outline-none focus:ring-2 focus:ring-sky-500 transition-all" placeholder="?">
            <div class="w-0.5 h-2 bg-sky-500 mt-1"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">124</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
        </div>
      </div>

      <div class="bg-slate-50/50 border border-slate-200/60 rounded-xl p-5 space-y-4">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block">Ejercicio 2</span>
        <div class="relative w-full flex justify-between items-center py-6 px-4 bg-white border border-slate-100 rounded-lg shadow-sm">
          <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-slate-300 -translate-y-1/2"></div>
          
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">345</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-16 bg-white">
            <input type="number" data-answer="346" required class="exercise-input w-16 text-center font-mono font-bold text-sm text-sky-700 bg-sky-50/50 border-2 border-sky-300 rounded-lg p-1 focus:outline-none focus:ring-2 focus:ring-sky-500 transition-all" placeholder="?">
            <div class="w-0.5 h-2 bg-sky-500 mt-1"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">347</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">348</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">349</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
        </div>
      </div>

      <div class="bg-slate-50/50 border border-slate-200/60 rounded-xl p-5 space-y-4">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block">Ejercicio 3</span>
        <div class="relative w-full flex justify-between items-center py-6 px-4 bg-white border border-slate-100 rounded-lg shadow-sm">
          <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-slate-300 -translate-y-1/2"></div>
          
          <div class="flex flex-col items-center relative z-10 w-16 bg-white">
            <input type="number" data-answer="599" required class="exercise-input w-16 text-center font-mono font-bold text-sm text-sky-700 bg-sky-50/50 border-2 border-sky-300 rounded-lg p-1 focus:outline-none focus:ring-2 focus:ring-sky-500 transition-all" placeholder="?">
            <div class="w-0.5 h-2 bg-sky-500 mt-1"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">600</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">601</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">602</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">603</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
        </div>
      </div>

      <div class="bg-slate-50/50 border border-slate-200/60 rounded-xl p-5 space-y-4">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block">Ejercicio 4</span>
        <div class="relative w-full flex justify-between items-center py-6 px-4 bg-white border border-slate-100 rounded-lg shadow-sm">
          <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-slate-300 -translate-y-1/2"></div>
          
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">897</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">898</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">899</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-12 bg-white">
            <span class="text-xs font-mono text-slate-500 mb-1">900</span>
            <div class="w-0.5 h-2 bg-slate-400"></div>
          </div>
          <div class="flex flex-col items-center relative z-10 w-16 bg-white">
            <input type="number" data-answer="901" required class="exercise-input w-16 text-center font-mono font-bold text-sm text-sky-700 bg-sky-50/50 border-2 border-sky-300 rounded-lg p-1 focus:outline-none focus:ring-2 focus:ring-sky-500 transition-all" placeholder="?">
            <div class="w-0.5 h-2 bg-sky-500 mt-1"></div>
          </div>
        </div>
      </div>

      <div class="text-center pt-4">
        <button id="btn-submit-practice" disabled class="inline-flex items-center gap-2 bg-slate-300 text-white text-xs font-bold px-8 py-3.5 rounded-xl transition-all shadow-sm cursor-not-allowed">
          🚀 Enviar respuestas
        </button>
      </div>
    </form>

    <div id="feedback-box" class="hidden opacity-0 transform translate-y-2 transition-all duration-500">
      <section id="feedback-card" class="rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-center sm:items-start border">
        
        <div class="flex justify-center shrink-0 relative w-20 h-20">
          <Image 
            id="img-torogoz-think"
            src={dibujoPedagogico} 
            alt="Torogoz pensando" 
            class="absolute inset-0 w-full h-full object-contain drop-shadow-sm select-none transition-opacity duration-200"
          />
          <Image 
            id="img-torogoz-success"
            src={dibujoSuccess} 
            alt="Torogoz celebrando" 
            class="absolute inset-0 w-full h-full object-contain drop-shadow-sm select-none transition-opacity duration-200 opacity-0"
          />
        </div>

        <div class="flex-1 space-y-2 text-center sm:text-left">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
            <h4 id="feedback-title" class="text-sm font-bold uppercase tracking-wider"></h4>
            <span id="score-badge" class="inline-block text-xs font-mono font-bold px-2.5 py-1 rounded-md"></span>
          </div>
          <p id="feedback-text" class="text-slate-600 text-sm leading-relaxed"></p>
        </div>
      </section>

      <div class="text-center pt-8">
        <a href="/second_content" class="inline-flex items-center gap-2 bg-sky-600 hover:bg-sky-700 text-white text-sm font-bold px-8 py-3.5 rounded-xl transition-all shadow-md hover:shadow-lg active:scale-95">
          Regresar al inicio
          <span>→</span>
        </a>
      </div>
    </div>

  </div>
</Layout>

<script>
  const inputs = document.querySelectorAll('.exercise-input');
  const btnSubmit = document.getElementById('btn-submit-practice') as HTMLButtonElement;
  const feedbackBox = document.getElementById('feedback-box');
  const feedbackCard = document.getElementById('feedback-card');
  const feedbackTitle = document.getElementById('feedback-title');
  const feedbackText = document.getElementById('feedback-text');
  const scoreBadge = document.getElementById('score-badge');
  
  const imgThink = document.getElementById('img-torogoz-think');
  const imgSuccess = document.getElementById('img-torogoz-success');
  const displayNameElem = document.getElementById('student-display-name');

  const nombreEstudiante = sessionStorage.getItem('student_name') || 'estudiante';

  if (displayNameElem) {
    displayNameElem.textContent = nombreEstudiante;
  }

  function verificarFormulario() {
    let todosLlenos = true;
    inputs.forEach(input => {
      if (!(input as HTMLInputElement).value.trim()) {
        todosLlenos = false;
      }
    });

    if (btnSubmit) {
      if (todosLlenos) {
        btnSubmit.disabled = false;
        btnSubmit.className = "inline-flex items-center gap-2 bg-sky-600 hover:bg-sky-700 text-white text-xs font-bold px-8 py-3.5 rounded-xl transition-all shadow-md hover:shadow-lg active:scale-95 cursor-pointer";
      } else {
        btnSubmit.disabled = true;
        btnSubmit.className = "inline-flex items-center gap-2 bg-slate-300 text-white text-xs font-bold px-8 py-3.5 rounded-xl transition-all shadow-sm cursor-not-allowed";
      }
    }
  }

  inputs.forEach(input => {
    input.addEventListener('input', verificarFormulario);
  });

  async function enviarNotaAPI(notaObtenida: number) {
    try {
      const response = await fetch('http://localhost:3000/api/grades/', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          userId: nombreEstudiante,
          topic: '4.2 Practica Teclado Recta',
          score: notaObtenida
        })
      });

      if (!response.ok) {
        throw new Error(`HTTP Error: ${response.status}`);
      }
    } catch (error) {
      console.error('Error al sincronizar la calificacion:', error);
    }
  }

  btnSubmit?.addEventListener('click', () => {
    if (!feedbackBox || !feedbackCard || !feedbackTitle || !feedbackText || !scoreBadge) return;

    let aciertos = 0;

    inputs.forEach(input => {
      const el = input as HTMLInputElement;
      const respuestaCorrecta = el.getAttribute('data-answer');
      el.disabled = true;

      if (el.value.trim() === respuestaCorrecta) {
        aciertos++;
        el.classList.remove('border-sky-300', 'bg-sky-50/50', 'text-sky-700');
        el.classList.add('border-emerald-400', 'bg-emerald-50', 'text-emerald-700');
      } else {
        el.classList.remove('border-sky-300', 'bg-sky-50/50', 'text-sky-700');
        el.classList.add('border-rose-400', 'bg-rose-50', 'text-rose-700');
      }
    });

    let notaFinal = 0;
    if (aciertos === 1) notaFinal = 2.5;
    if (aciertos === 2) notaFinal = 5;
    if (aciertos === 3) notaFinal = 7.5;
    if (aciertos === 4) notaFinal = 10;

    feedbackBox.classList.remove('hidden');
    setTimeout(() => {
      feedbackBox.classList.remove('opacity-0', 'translate-y-2');
      feedbackBox.classList.add('opacity-100', 'translate-y-0');
    }, 5);

    btnSubmit.classList.add('hidden');

    if (notaFinal === 10) {
      if (imgThink && imgSuccess) {
        imgThink.classList.add('opacity-0');
        imgSuccess.classList.remove('opacity-0');
        imgSuccess.classList.add('opacity-100');
      }

      feedbackCard.className = "bg-emerald-50/70 border-emerald-100 rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-center sm:items-start border";
      feedbackTitle.className = "text-sm font-bold uppercase tracking-wider text-emerald-800";
      feedbackTitle.textContent = `¡Perfecto, ${nombreEstudiante}! 🏆`;
      feedbackText.textContent = `¡Impresionante! Completaste los ${aciertos} de 4 ejercicios de forma correcta. Tienes un dominio excelente de las rectas numéricas.`;
      
      scoreBadge.className = "inline-block text-xs font-mono font-bold px-2.5 py-1 rounded-md bg-emerald-100 text-emerald-800 border border-emerald-200";
      scoreBadge.textContent = `Nota: ${notaFinal}/10 (${aciertos}/4 aciertos)`;
    } else {
      if (imgThink && imgSuccess) {
        imgThink.classList.remove('opacity-0');
        imgThink.classList.add('opacity-100');
        imgSuccess.classList.remove('opacity-100');
        imgSuccess.classList.add('opacity-0');
        imgThink.style.filter = "grayscale(30%) contrast(95%)";
      }

      feedbackCard.className = "bg-amber-50/80 border-amber-100 rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-center sm:items-start border";
      feedbackTitle.className = "text-sm font-bold uppercase tracking-wider text-amber-800";
      feedbackTitle.textContent = "¡Buen esfuerzo!";
      feedbackText.textContent = "¡Continúa practicando en casa! No te desanimes, sigue aprendiendo sobre las rectas numéricas y podrás mejorar en los siguientes ejercicios.";
      
      scoreBadge.className = "inline-block text-xs font-mono font-bold px-2.5 py-1 rounded-md bg-amber-100 text-amber-800 border border-amber-200";
      scoreBadge.textContent = `Nota: ${notaFinal}/10 (${aciertos}/4 aciertos)`;
    }

    enviarNotaAPI(notaFinal);
    feedbackBox.scrollIntoView({ behavior: 'smooth', block: 'end' });
  });
</script>